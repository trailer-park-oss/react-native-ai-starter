{
  "name": "@trailer-park-oss/create-rn-ai-starter",
  "version": "0.1.0",
  "description": "CLI to scaffold Expo React Native projects with modular feature packs",
  "type": "module",
  "bin": {
    "create-rn-ai-starter": "./dist/index.js"
  },
  "files": [

  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=18"
  }
}

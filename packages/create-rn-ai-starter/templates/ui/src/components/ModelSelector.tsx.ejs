import { useState, useEffect, useCallback } from 'react'
import {
  ActivityIndicator,
  FlatList,
  KeyboardAvoidingView,
  Modal,
  Platform,
  Text,
  TextInput,
  TouchableOpacity,
  View,
} from 'react-native'
import { useTokens } from '@/design-system'

interface ModelOption {
  id: string
  name: string
  description: string
  pricing?: string
}

interface ModelSearchProps {
  visible: boolean
  onClose: () => void
  onSelect: (model: ModelOption) => void
  fetchModels: (searchTerm?: string) => Promise<ModelOption[]>
  initialSelectedId?: string
  isExecuTorch?: boolean
  downloadedModels?: string[]
  onDownload?: (model: ModelOption) => Promise<void>
  onDelete?: (model: ModelOption) => Promise<void>
}

export function ModelSearch({
  visible,
  onClose,
  onSelect,
  fetchModels,
  initialSelectedId,
  isExecuTorch = false,
  downloadedModels = [],
  onDownload,
  onDelete,
}: ModelSearchProps) {
  const { colors, spacing, radius, typography } = useTokens()
  const [searchQuery, setSearchQuery] = useState('')
  const [models, setModels] = useState<ModelOption[]>([])
  const [filteredModels, setFilteredModels] = useState<ModelOption[]>([])
  const [isLoading, setIsLoading] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [downloadingModels, setDownloadingModels] = useState<Set<string>>(new Set())
  const [deletingModels, setDeletingModels] = useState<Set<string>>(new Set())

  const loadModels = useCallback(async () => {
    setIsLoading(true)
    setError(null)
    try {
      const fetched = await fetchModels()
      setModels(fetched)
      setFilteredModels(fetched)
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to load models')
    } finally {
      setIsLoading(false)
    }
  }, [fetchModels])

  useEffect(() => {
    if (visible) {
      loadModels()
    }
  }, [visible, loadModels])

  useEffect(() => {
    if (!searchQuery) {
      setFilteredModels(models)
      return
    }

    const term = searchQuery.toLowerCase()
    const filtered = models.filter(
      (m) =>
        m.name.toLowerCase().includes(term) ||
        m.id.toLowerCase().includes(term) ||
        m.description.toLowerCase().includes(term),
    )
    setFilteredModels(filtered)
  }, [searchQuery, models])

  const renderItem = ({ item }: { item: ModelOption }) => {
    const isSelected = item.id === initialSelectedId
    const isDownloaded = downloadedModels.includes(item.id)
    const isDownloading = downloadingModels.has(item.id)
    const isDeleting = deletingModels.has(item.id)

    return (
      <TouchableOpacity
        onPress={() => {
          onSelect(item)
          onClose()
        }}
        disabled={isDeleting}
        style={{
          padding: spacing.md,
          borderBottomWidth: 1,
          borderBottomColor: colors.borderSubtle,
          backgroundColor: isSelected ? colors.primarySubtle : 'transparent',
        }}
      >
        <Text
          style={{
            fontSize: typography.body.fontSize,
            fontWeight: '600',
            color: isSelected ? colors.primary : colors.text,
            marginBottom: spacing.xs,
          }}
        >
          {item.name}
        </Text>
        <Text
          style={{
            fontSize: typography.caption.fontSize,
            color: colors.textSubtle,
            marginBottom: spacing.xs / 2,
          }}
        >
          {item.description}
        </Text>
        {item.pricing && (
          <Text
            style={{
              fontSize: typography.caption.fontSize,
              color: colors.info,
              marginBottom: spacing.xs / 2,
            }}
          >
            {item.pricing}
          </Text>
        )}

        {isExecuTorch && (
          <>
            {isDownloaded ? (
              <TouchableOpacity
                onPress={async () => {
                  if (!onDelete) return
                  setDeletingModels((prev) => new Set(prev).add(item.id))
                  try {
                    await onDelete(item)
                  } finally {
                    setDeletingModels((prev) => {
                      const next = new Set(prev)
                      next.delete(item.id)
                      return next
                    })
                  }
                }}
                style={{
                  marginTop: spacing.xs,
                  backgroundColor: colors.criticalSubtle,
                  paddingVertical: spacing.xs,
                  paddingHorizontal: spacing.sm,
                  borderRadius: radius.sm,
                  alignSelf: 'flex-start',
                }}
                disabled={isDeleting}
              >
                <Text
                  style={{
                    fontSize: typography.caption.fontSize,
                    color: colors.critical,
                    fontWeight: '600',
                  }}
                >
                  {isDeleting ? 'Deleting...' : 'Delete'}
                </Text>
              </TouchableOpacity>
            ) : (
              <TouchableOpacity
                onPress={async () => {
                  if (!onDownload) return
                  setDownloadingModels((prev) => new Set(prev).add(item.id))
                  try {
                    await onDownload(item)
                  } finally {
                    setDownloadingModels((prev) => {
                      const next = new Set(prev)
                      next.delete(item.id)
                      return next
                    })
                  }
                }}
                style={{
                  marginTop: spacing.xs,
                  backgroundColor: colors.primary,
                  paddingVertical: spacing.xs,
                  paddingHorizontal: spacing.sm,
                  borderRadius: radius.sm,
                  alignSelf: 'flex-start',
                }}
                disabled={isDownloading}
              >
                <Text
                  style={{
                    fontSize: typography.caption.fontSize,
                    color: colors.textOnPrimary,
                    fontWeight: '600',
                  }}
                >
                  {isDownloading ? 'Downloading...' : 'Download'}
                </Text>
              </TouchableOpacity>
            )}
          </>
        )}
      </TouchableOpacity>
    )
  }

  return (
    <Modal
      visible={visible}
      animationType="slide"
      onRequestClose={onClose}
      presentationStyle="pageSheet"
    >
      <KeyboardAvoidingView
        style={{ flex: 1, backgroundColor: colors.background }}
        behavior={Platform.OS === 'ios' ? 'padding' : undefined}
        keyboardVerticalOffset={0}
      >
        <View
          style={{
            flexDirection: 'row',
            alignItems: 'center',
            justifyContent: 'space-between',
            padding: spacing.md,
            borderBottomWidth: 1,
            borderBottomColor: colors.border,
          }}
        >
          <Text
            style={{
              fontSize: typography.heading.fontSize,
              fontWeight: '600',
              color: colors.text,
            }}
          >
            Select Model
          </Text>
          <TouchableOpacity onPress={onClose}>
            <Text style={{ fontSize: 18, color: colors.primary }}>Done</Text>
          </TouchableOpacity>
        </View>

        <View style={{ padding: spacing.md }}>
          <TextInput
            style={{
              backgroundColor: colors.surfaceRaised,
              color: colors.text,
              fontSize: typography.body.fontSize,
              borderRadius: radius.md,
              paddingHorizontal: spacing.md,
              paddingVertical: spacing.sm + 2,
            }}
            value={searchQuery}
            onChangeText={setSearchQuery}
            placeholder="Search models..."
            placeholderTextColor={colors.textSubtle}
            autoCapitalize="none"
            autoCorrect={false}
          />
        </View>

        {isLoading ? (
          <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
            <ActivityIndicator size="large" color={colors.primary} />
            <Text
              style={{
                marginTop: spacing.md,
                color: colors.textSubtle,
                fontSize: typography.body.fontSize,
              }}
            >
              Loading models...
            </Text>
          </View>
        ) : error ? (
          <View style={{ padding: spacing.md }}>
            <Text style={{ color: colors.critical, fontSize: typography.body.fontSize }}>
              {error}
            </Text>
            <TouchableOpacity
              onPress={loadModels}
              style={{
                marginTop: spacing.md,
                alignSelf: 'flex-start',
                paddingVertical: spacing.sm,
                paddingHorizontal: spacing.md,
                backgroundColor: colors.primary,
                borderRadius: radius.md,
              }}
            >
              <Text style={{ color: colors.textOnPrimary, fontWeight: '600' }}>Retry</Text>
            </TouchableOpacity>
          </View>
      ) : (
        <>
          {isExecuTorch && downloadedModels.length > 0 && (
            <View
              style={{
                padding: spacing.md,
                borderBottomWidth: 1,
                borderBottomColor: colors.borderSubtle,
              }}
            >
              <Text
                style={{
                  fontSize: typography.body.fontSize,
                  fontWeight: '600',
                  color: colors.text,
                  marginBottom: spacing.xs,
                }}
              >
                Downloaded Models ({downloadedModels.length})
              </Text>
              {downloadedModels.map((modelId) => {
                const model = models.find((m) => m.id === modelId)
                if (!model) return null
                return (
                  <TouchableOpacity
                    key={model.id}
                    onPress={() => {
                      onSelect(model)
                      onClose()
                    }}
                    style={{
                      marginTop: spacing.sm,
                      backgroundColor: colors.successSubtle,
                      padding: spacing.sm,
                      borderRadius: radius.sm,
                    }}
                  >
                    <Text
                      style={{
                        fontSize: typography.body.fontSize,
                        fontWeight: '600',
                        color: colors.success,
                      }}
                    >
                      {model.name}
                    </Text>
                    <Text
                      style={{
                        fontSize: typography.caption.fontSize,
                        color: colors.textSubtle,
                        marginTop: spacing.xs / 2,
                      }}
                    >
                      {model.id}
                    </Text>
                  </TouchableOpacity>
                )
              })}
            </View>
          )}

          <Text
            style={{
              fontSize: typography.caption.fontSize,
              color: colors.textSubtle,
              paddingHorizontal: spacing.md,
              paddingTop: spacing.md,
              paddingBottom: spacing.xs,
            }}
          >
            {isExecuTorch ? 'Available Models' : 'All Models'}
          </Text>

          <FlatList
            data={filteredModels}
            keyExtractor={(item) => item.id}
            renderItem={renderItem}
            ListEmptyComponent={
              <View
                style={{
                  padding: spacing.xl,
                  alignItems: 'center',
                }}
              >
                <Text style={{ color: colors.textSubtle, fontSize: typography.body.fontSize }}>
                  No models found
                </Text>
              </View>
            }
          />
        </>
      )}
      </KeyboardAvoidingView>
    </Modal>
  )
}

interface ModelSelectorProps {
  selectedModel: string
  modelName: string
  onShowSelector: () => void
  isDownloaded?: boolean
}

export function ModelSelector({ selectedModel, modelName, onShowSelector, isDownloaded = false }: ModelSelectorProps) {
  const { colors, spacing, radius, typography } = useTokens()

  return (
    <TouchableOpacity
      onPress={onShowSelector}
      style={{
        backgroundColor: colors.surfaceRaised,
        borderRadius: radius.md,
        padding: spacing.md,
        marginHorizontal: spacing.md,
        marginBottom: spacing.sm,
      }}
    >
      <Text
        style={{
          fontSize: typography.caption.fontSize,
          color: colors.textSubtle,
          marginBottom: spacing.xs,
        }}
      >
        Model
      </Text>
      <View
        style={{
          flexDirection: 'row',
          alignItems: 'center',
          justifyContent: 'space-between',
        }}
      >
        <Text
          style={{
            fontSize: typography.bodyLarge.fontSize,
            fontWeight: '600',
            color: colors.text,
            flex: 1,
          }}
          numberOfLines={1}
        >
          {modelName}
        </Text>
        <View
          style={{
            flexDirection: 'row',
            alignItems: 'center',
            gap: spacing.sm,
          }}
        >
          {isDownloaded !== undefined && (
            <Text
              style={{
                fontSize: typography.caption.fontSize,
                color: isDownloaded ? colors.success : colors.textSubtle,
              }}
            >
              {isDownloaded ? '✓ Downloaded' : 'Not downloaded'}
            </Text>
          )}
          <Text style={{ color: colors.primary, fontSize: typography.body.fontSize }}>
            Change
          </Text>
        </View>
      </View>
      <Text
        style={{
          fontSize: typography.caption.fontSize,
          color: colors.textSubtle,
          marginTop: spacing.xs / 2,
        }}
        numberOfLines={1}
      >
        {selectedModel}
      </Text>
    </TouchableOpacity>
  )
}

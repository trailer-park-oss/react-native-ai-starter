import { useState } from 'react'
import { <%= uiKit.VStack %>, Text } from '<%= uiKit.lib %>'
import { TextInput, Pressable, KeyboardAvoidingView, Platform, ScrollView } from 'react-native'
import { useRouter } from 'expo-router'
import { useForm, Controller } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { forgotPasswordSchema, type ForgotPasswordFormData } from '@/providers/auth/auth.schemas'
import { useAuth } from '@/providers/auth/useAuth'
import { useTokens } from '@/design-system'
import { PrimaryButton } from '@/components/PrimaryButton'
import type { AuthError } from '@/providers/auth/auth.interface'

export default function ForgotPasswordScreen() {
  const router = useRouter()
  const { resetPassword } = useAuth()
  const { colors, typography, spacing, radius } = useTokens()
  const [authError, setAuthError] = useState<AuthError | null>(null)
  const [sent, setSent] = useState(false)

  const { control, handleSubmit, formState: { errors, isSubmitting } } = useForm<ForgotPasswordFormData>({
    resolver: zodResolver(forgotPasswordSchema),
    defaultValues: { email: '' },
  })

  const onSubmit = async (data: ForgotPasswordFormData) => {
    setAuthError(null)
    try {
      await resetPassword(data.email)
      setSent(true)
    } catch (err) {
      setAuthError({
        code: 'UNKNOWN',
        message: err instanceof Error ? err.message : 'Something went wrong',
      })
    }
  }

  if (sent) {
    return (
      <<%= uiKit.VStack %>
        style={{
          flex: 1,
          justifyContent: 'center',
          alignItems: 'center',
          padding: spacing.lg,
          backgroundColor: colors.background,
        }}
      >
        <<%= uiKit.VStack %>
          style={{
            backgroundColor: colors.successSubtle,
            padding: spacing.lg,
            borderRadius: radius.lg,
            alignItems: 'center',
            width: '100%',
          }}
        >
          <Text
            style={{
              fontSize: typography.heading.fontSize,
              fontWeight: typography.heading.fontWeight,
              color: colors.text,
              marginBottom: spacing.sm,
            }}
          >
            Check your email
          </Text>
          <Text
            style={{
              fontSize: typography.body.fontSize,
              color: colors.textSubtle,
              textAlign: 'center',
              marginBottom: spacing.lg,
            }}
          >
            We've sent a password reset link to your email address.
          </Text>
        </<%= uiKit.VStack %>>
        <Pressable
          onPress={() => router.back()}
          style={{ marginTop: spacing.lg }}
        >
          <Text style={{ color: colors.primary, fontSize: typography.body.fontSize, fontWeight: '500' }}>
            Back to sign in
          </Text>
        </Pressable>
      </<%= uiKit.VStack %>>
    )
  }

  return (
    <KeyboardAvoidingView
      style={{ flex: 1, backgroundColor: colors.background }}
      behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
    >
      <ScrollView
        contentContainerStyle={{ flexGrow: 1, justifyContent: 'center' }}
        keyboardShouldPersistTaps="handled"
      >
        <<%= uiKit.VStack %>
          style={{
            flex: 1,
            justifyContent: 'center',
            padding: spacing.lg,
          }}
        >
          <Text
            style={{
              fontSize: typography.headingLarge.fontSize,
              fontWeight: typography.headingLarge.fontWeight,
              color: colors.text,
              marginBottom: spacing.xs,
            }}
          >
            Reset password
          </Text>
          <Text
            style={{
              fontSize: typography.body.fontSize,
              color: colors.textSubtle,
              marginBottom: spacing.xl,
            }}
          >
            Enter your email and we'll send you a reset link
          </Text>

          {authError && (
            <<%= uiKit.VStack %>
              style={{
                backgroundColor: colors.criticalSubtle,
                padding: spacing.md,
                borderRadius: radius.md,
                marginBottom: spacing.md,
              }}
            >
              <Text style={{ color: colors.critical, fontSize: typography.body.fontSize }}>
                {authError.message}
              </Text>
            </<%= uiKit.VStack %>>
          )}

          <Controller
            control={control}
            name="email"
            render={({ field: { onChange, onBlur, value } }) => (
              <<%= uiKit.VStack %> style={{ marginBottom: spacing.lg }}>
                <Text
                  style={{
                    fontSize: typography.body.fontSize,
                    fontWeight: '500',
                    color: colors.text,
                    marginBottom: spacing.xs,
                  }}
                >
                  Email
                </Text>
                <TextInput
                  value={value}
                  onChangeText={onChange}
                  onBlur={onBlur}
                  placeholder="you@example.com"
                  placeholderTextColor={colors.textSubtle}
                  autoCapitalize="none"
                  autoComplete="email"
                  keyboardType="email-address"
                  style={{
                    borderWidth: 1,
                    borderColor: errors.email ? colors.critical : colors.border,
                    borderRadius: radius.md,
                    padding: spacing.md,
                    fontSize: typography.body.fontSize,
                    color: colors.text,
                    backgroundColor: colors.surface,
                  }}
                />
                {errors.email && (
                  <Text style={{ color: colors.critical, fontSize: typography.caption.fontSize, marginTop: spacing.xs }}>
                    {errors.email.message}
                  </Text>
                )}
              </<%= uiKit.VStack %>>
            )}
          />

          <PrimaryButton
            label={isSubmitting ? 'Sending...' : 'Send Reset Link'}
            onPress={handleSubmit(onSubmit)}
            disabled={isSubmitting}
          />

          <Pressable
            onPress={() => router.back()}
            style={{ marginTop: spacing.lg, alignItems: 'center' }}
          >
            <Text style={{ color: colors.primary, fontSize: typography.body.fontSize, fontWeight: '500' }}>
              Back to sign in
            </Text>
          </Pressable>
        </<%= uiKit.VStack %>>
      </ScrollView>
    </KeyboardAvoidingView>
  )
}

import { useState } from 'react'
import { <%= uiKit.VStack %>, Text } from '<%= uiKit.lib %>'
import { TextInput, Pressable, ActivityIndicator, KeyboardAvoidingView, Platform, ScrollView } from 'react-native'
import { useRouter } from 'expo-router'
import { useForm, Controller } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { signInSchema, type SignInFormData } from '@/providers/auth/auth.schemas'
import { useAuth } from '@/providers/auth/useAuth'
import { useTokens } from '@/design-system'
import { PrimaryButton } from '@/components/PrimaryButton'
import type { AuthError } from '@/providers/auth/auth.interface'

export default function SignInScreen() {
  const router = useRouter()
  const { signIn, signInWithOAuth } = useAuth()
  const { colors, typography, spacing, radius } = useTokens()
  const [authError, setAuthError] = useState<AuthError | null>(null)

  const { control, handleSubmit, formState: { errors, isSubmitting } } = useForm<SignInFormData>({
    resolver: zodResolver(signInSchema),
    defaultValues: { email: '', password: '' },
  })

  const onSubmit = async (data: SignInFormData) => {
    setAuthError(null)
    const result = await signIn(data)
    if (result.success) {
      router.replace('/')
    } else {
      setAuthError(result.error)
    }
  }

  const handleOAuth = async (provider: 'google' | 'apple') => {
    setAuthError(null)
    const result = await signInWithOAuth(provider)
    if (!result.success) {
      setAuthError(result.error)
    }
  }

  return (
    <KeyboardAvoidingView
      style={{ flex: 1, backgroundColor: colors.background }}
      behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
    >
      <ScrollView
        contentContainerStyle={{ flexGrow: 1, justifyContent: 'center' }}
        keyboardShouldPersistTaps="handled"
      >
        <<%= uiKit.VStack %>
          style={{
            flex: 1,
            justifyContent: 'center',
            padding: spacing.lg,
          }}
        >
          <Text
            style={{
              fontSize: typography.headingLarge.fontSize,
              fontWeight: typography.headingLarge.fontWeight,
              color: colors.text,
              marginBottom: spacing.xs,
            }}
          >
            Welcome back
          </Text>
          <Text
            style={{
              fontSize: typography.body.fontSize,
              color: colors.textSubtle,
              marginBottom: spacing.xl,
            }}
          >
            Sign in to your account
          </Text>

          {authError && (
            <<%= uiKit.VStack %>
              style={{
                backgroundColor: colors.criticalSubtle,
                padding: spacing.md,
                borderRadius: radius.md,
                marginBottom: spacing.md,
              }}
            >
              <Text style={{ color: colors.critical, fontSize: typography.body.fontSize }}>
                {authError.message}
              </Text>
            </<%= uiKit.VStack %>>
          )}

          <Controller
            control={control}
            name="email"
            render={({ field: { onChange, onBlur, value } }) => (
              <<%= uiKit.VStack %> style={{ marginBottom: spacing.md }}>
                <Text
                  style={{
                    fontSize: typography.body.fontSize,
                    fontWeight: '500',
                    color: colors.text,
                    marginBottom: spacing.xs,
                  }}
                >
                  Email
                </Text>
                <TextInput
                  value={value}
                  onChangeText={onChange}
                  onBlur={onBlur}
                  placeholder="you@example.com"
                  placeholderTextColor={colors.textSubtle}
                  autoCapitalize="none"
                  autoComplete="email"
                  keyboardType="email-address"
                  style={{
                    borderWidth: 1,
                    borderColor: errors.email ? colors.critical : colors.border,
                    borderRadius: radius.md,
                    padding: spacing.md,
                    fontSize: typography.body.fontSize,
                    color: colors.text,
                    backgroundColor: colors.surface,
                  }}
                />
                {errors.email && (
                  <Text style={{ color: colors.critical, fontSize: typography.caption.fontSize, marginTop: spacing.xs }}>
                    {errors.email.message}
                  </Text>
                )}
              </<%= uiKit.VStack %>>
            )}
          />

          <Controller
            control={control}
            name="password"
            render={({ field: { onChange, onBlur, value } }) => (
              <<%= uiKit.VStack %> style={{ marginBottom: spacing.md }}>
                <Text
                  style={{
                    fontSize: typography.body.fontSize,
                    fontWeight: '500',
                    color: colors.text,
                    marginBottom: spacing.xs,
                  }}
                >
                  Password
                </Text>
                <TextInput
                  value={value}
                  onChangeText={onChange}
                  onBlur={onBlur}
                  placeholder="Enter your password"
                  placeholderTextColor={colors.textSubtle}
                  secureTextEntry
                  autoComplete="password"
                  style={{
                    borderWidth: 1,
                    borderColor: errors.password ? colors.critical : colors.border,
                    borderRadius: radius.md,
                    padding: spacing.md,
                    fontSize: typography.body.fontSize,
                    color: colors.text,
                    backgroundColor: colors.surface,
                  }}
                />
                {errors.password && (
                  <Text style={{ color: colors.critical, fontSize: typography.caption.fontSize, marginTop: spacing.xs }}>
                    {errors.password.message}
                  </Text>
                )}
              </<%= uiKit.VStack %>>
            )}
          />

          <Pressable onPress={() => router.push('/(auth)/forgot-password')}>
            <Text
              style={{
                fontSize: typography.body.fontSize,
                color: colors.primary,
                textAlign: 'right',
                marginBottom: spacing.lg,
              }}
            >
              Forgot password?
            </Text>
          </Pressable>

          <PrimaryButton
            label={isSubmitting ? 'Signing in...' : 'Sign In'}
            onPress={handleSubmit(onSubmit)}
            disabled={isSubmitting}
          />

          <<%= uiKit.VStack %>
            style={{
              marginTop: spacing.xl,
              alignItems: 'center',
              gap: spacing.md,
            }}
          >
            <Text style={{ color: colors.textSubtle, fontSize: typography.body.fontSize }}>
              Or continue with
            </Text>

            <<%= uiKit.VStack %> style={{ flexDirection: 'row', gap: spacing.md }}>
              <Pressable
                onPress={() => handleOAuth('google')}
                disabled={isSubmitting}
                style={{
                  flex: 1,
                  borderWidth: 1,
                  borderColor: colors.border,
                  borderRadius: radius.md,
                  padding: spacing.md,
                  alignItems: 'center',
                }}
              >
                <Text style={{ color: colors.text, fontSize: typography.body.fontSize, fontWeight: '500' }}>
                  Google
                </Text>
              </Pressable>
              <Pressable
                onPress={() => handleOAuth('apple')}
                disabled={isSubmitting}
                style={{
                  flex: 1,
                  borderWidth: 1,
                  borderColor: colors.border,
                  borderRadius: radius.md,
                  padding: spacing.md,
                  alignItems: 'center',
                }}
              >
                <Text style={{ color: colors.text, fontSize: typography.body.fontSize, fontWeight: '500' }}>
                  Apple
                </Text>
              </Pressable>
            </<%= uiKit.VStack %>>
          </<%= uiKit.VStack %>>

          <Pressable
            onPress={() => router.push('/(auth)/sign-up')}
            style={{ marginTop: spacing.xl, alignItems: 'center' }}
          >
            <Text style={{ color: colors.textSubtle, fontSize: typography.body.fontSize }}>
              Don't have an account?{' '}
              <Text style={{ color: colors.primary, fontWeight: '500' }}>Sign up</Text>
            </Text>
          </Pressable>
        </<%= uiKit.VStack %>>
      </ScrollView>
    </KeyboardAvoidingView>
  )
}
